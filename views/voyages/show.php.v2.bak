<?php
/** @var \CityBus\Core\View $view */
$view->extends('layouts/app');
use CityBus\Models\Trip;

$booked     = array_flip(array_map('intval', $bookedSeats));
$totalSeats = (int)($trip['bus_seats'] ?? 0);
$soldCount  = count($bookedSeats);
$occupancy  = $totalSeats > 0 ? round($soldCount / $totalSeats * 100) : 0;
$revenue    = (int)($trip['total_revenue'] ?? 0);
$delay      = (int)($trip['delay_minutes'] ?? 0);
$tolerance  = \CityBus\Core\Setting::getInt('voyage.delay_tolerance_minutes', 15);

$statusMeta = [
  'planifie'     => ['label'=>'Planifié',    'cls'=>'bg-slate-100 text-slate-600 border-slate-200',         'dot'=>'bg-slate-400',  'icon'=>'clock'],
  'valide'       => ['label'=>'Validé',      'cls'=>'bg-cyan-50 text-cyan-700 border-cyan-200',             'dot'=>'bg-cyan-500',   'icon'=>'check'],
  'embarquement' => ['label'=>'Embarquement','cls'=>'bg-amber-50 text-amber-700 border-amber-200',          'dot'=>'bg-amber-400',  'icon'=>'users'],
  'en_route'     => ['label'=>'En route',    'cls'=>'bg-cb-primary text-white border-cb-primary',           'dot'=>'bg-white',      'icon'=>'navigation'],
  'arrive'       => ['label'=>'Arrivé',      'cls'=>'bg-emerald-50 text-emerald-700 border-emerald-200',    'dot'=>'bg-emerald-500','icon'=>'map-pin'],
  'cloture'      => ['label'=>'Clôturé',     'cls'=>'bg-emerald-100 text-emerald-800 border-emerald-300',   'dot'=>'bg-emerald-600','icon'=>'check-circle'],
  'incident'     => ['label'=>'Incident',    'cls'=>'bg-rose-50 text-rose-700 border-rose-200',             'dot'=>'bg-rose-500',   'icon'=>'alert-triangle'],
  'retourne'     => ['label'=>'Retourné',    'cls'=>'bg-orange-50 text-orange-700 border-orange-200',       'dot'=>'bg-orange-500', 'icon'=>'undo-2'],
  'litige'       => ['label'=>'Litige',      'cls'=>'bg-purple-50 text-purple-700 border-purple-200',       'dot'=>'bg-purple-500', 'icon'=>'gavel'],
  'annule'       => ['label'=>'Annulé',      'cls'=>'bg-rose-50 text-rose-600 border-rose-200',             'dot'=>'bg-rose-400',   'icon'=>'x-circle'],
];
$sm = $statusMeta[$trip['status']] ?? $statusMeta['planifie'];

$crewByRole = [];
foreach ($crew as $c) { $crewByRole[$c['role']][] = $c; }

$passengerTickets = array_values(array_filter($tickets, fn($t) => in_array($t['ticket_type'], ['passager','arret_route','finale'])));
$baggageTickets   = array_values(array_filter($tickets, fn($t) => in_array($t['ticket_type'], ['bagage_franchise','bagage_excedent'])));

$tabs = [
  'details'      => ['Vue d\'ensemble','layout-dashboard',null],
  'passengers'   => ['Passagers','users',count($passengerTickets)],
  'cargo'        => ['Cargo','package',count($parcels ?? [])],
  'reservations' => ['Réservations','clipboard-list',count($reservations ?? [])],
  'waitlist'     => ['Liste d\'attente','users-2',count($waitlist ?? [])],
  'inspection'   => ['Pré-vérif','clipboard-check', $inspection ? 1 : 0],
  'pnl'          => ['P&L','trending-up', $pnl ? 1 : null],
  'documents'    => ['Documents','file-text',count($documents ?? [])],
  'costs'        => ['Coûts','wallet',count($costs ?? [])],
  'disputes'     => ['Litiges','gavel',count($disputes ?? [])],
  'messages'     => ['Communication','message-square',count($messages ?? [])],
  'audit'        => ['Audit','history',count($statusTimeline ?? [])],
];
$activeTab = $activeTab ?? 'details';
?>
<?php $view->start('content') ?>
<div class="space-y-5" x-data="{ tab: '<?= e($activeTab) ?>', actions: false }" x-cloak>

  <!-- ── Fil d'Ariane ─────────────────────────────────── -->
  <div class="flex items-center gap-2 text-sm text-slate-500">
    <a href="<?= e(url('voyages')) ?>" class="hover:text-cb-primary inline-flex items-center gap-1">
      <i data-lucide="chevron-left" class="w-4 h-4"></i> Voyages
    </a>
    <span>/</span>
    <span class="text-slate-800 font-mono font-semibold"><?= e($trip['trip_code']) ?></span>
    <?php if (!empty($trip['parent_trip_code'])): ?>
      <span>·</span>
      <span class="text-xs px-2 py-0.5 rounded bg-amber-50 text-amber-700">remplace
        <a href="<?= e(url('voyages?search=' . urlencode($trip['parent_trip_code']))) ?>" class="font-mono underline"><?= e($trip['parent_trip_code']) ?></a>
      </span>
    <?php endif ?>
  </div>

  <!-- ── En-tête voyage ───────────────────────────────── -->
  <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
    <div class="flex flex-wrap gap-4 items-start justify-between">
      <div class="flex items-start gap-4">
        <div class="w-14 h-14 rounded-2xl bg-cb-bg flex items-center justify-center shrink-0">
          <i data-lucide="bus" class="w-7 h-7 text-cb-primary"></i>
        </div>
        <div>
          <div class="flex items-center gap-2 flex-wrap">
            <h1 class="text-2xl font-bold text-slate-900"><?= e($trip['line_code']) ?> · <?= e($trip['line_name']) ?></h1>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold border <?= $sm['cls'] ?>">
              <i data-lucide="<?= e($sm['icon']) ?>" class="w-3.5 h-3.5"></i><?= $sm['label'] ?>
            </span>
            <?php if ($manifestLocked): ?>
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold bg-slate-900 text-white">
                <i data-lucide="lock" class="w-3 h-3"></i> Verrouillé
              </span>
            <?php endif ?>
            <?php if ($trip['priority'] && $trip['priority'] !== 'normale'): ?>
              <span class="px-2.5 py-1 rounded-full text-xs font-bold bg-purple-100 text-purple-700"><?= e(strtoupper($trip['priority'])) ?></span>
            <?php endif ?>
          </div>
          <p class="text-slate-500 text-sm mt-1 flex items-center gap-3 flex-wrap">
            <span class="flex items-center gap-1"><i data-lucide="calendar" class="w-3.5 h-3.5"></i><?= e(date_fr($trip['trip_date'])) ?></span>
            <span class="flex items-center gap-1"><i data-lucide="clock" class="w-3.5 h-3.5"></i>
              Prévu <?= e(substr($trip['departure_scheduled'], 0, 5)) ?>
              <?php if (!empty($trip['departure_actual'])): ?>
                <span class="<?= $delay > $tolerance ? 'text-rose-600 font-bold' : ($delay > 0 ? 'text-amber-600' : 'text-emerald-600') ?>">
                  · réel <?= e(substr($trip['departure_actual'], 0, 5)) ?>
                  <?php if ($delay !== 0): ?>(<?= $delay > 0 ? '+' : '' ?><?= $delay ?>min)<?php endif ?>
                </span>
              <?php endif ?>
            </span>
            <?php if (!empty($trip['arrival_actual'])): ?>
              <span class="flex items-center gap-1"><i data-lucide="map-pin" class="w-3.5 h-3.5"></i>Arrivé <?= e(substr($trip['arrival_actual'], 0, 5)) ?></span>
            <?php endif ?>
          </p>
          <p class="font-mono text-xs text-slate-400 mt-1"><?= e($trip['trip_code']) ?>
            <?php if (!empty($trip['external_reference'])): ?>· réf. <?= e($trip['external_reference']) ?><?php endif ?>
          </p>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-2 flex-wrap">
        <?php if (can('billetterie.create') && !$manifestLocked && !Trip::isTerminal($trip['status'])): ?>
          <a href="<?= e(url('billetterie/sale/'.$trip['id'])) ?>"
             class="px-4 py-2.5 rounded-xl bg-cb-primary text-white font-semibold inline-flex items-center gap-2 hover:bg-cb-dark shadow-soft">
            <i data-lucide="ticket" class="w-4 h-4"></i> Vendre ticket
          </a>
        <?php endif ?>
        <a href="<?= e(url('voyages/'.$trip['id'].'/manifest')) ?>"
