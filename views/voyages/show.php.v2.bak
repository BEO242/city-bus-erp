  <!-- ════ MODALES ════ -->

  <!-- Changer statut -->
  <div x-data="{ open: false }" @open-modal.window="if($event.detail==='status') open = true" x-show="open" x-cloak
       class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4" @click.self="open = false">
    <form method="post" action="<?= e(url('voyages/'.$trip['id'].'/status')) ?>" class="bg-white rounded-2xl p-6 max-w-md w-full" @click.stop>
      <?= csrf_field() ?>
      <h3 class="font-bold text-lg mb-4">Changer le statut</h3>
      <select name="status" required class="cb-input w-full mb-3">
        <?php foreach (Trip::STATUSES as $k => $lbl): ?>
          <option value="<?= e($k) ?>" <?= $trip['status']===$k?'selected':'' ?>><?= e($lbl) ?></option>
        <?php endforeach ?>
      </select>
      <textarea name="reason" rows="3" placeholder="Motif (obligatoire pour incident, annulation, retour, litige)" class="cb-input w-full"></textarea>
      <div class="flex justify-end gap-2 mt-4">
        <button type="button" @click="open=false" class="px-4 py-2 rounded-xl border border-slate-200">Annuler</button>
        <button class="px-4 py-2 rounded-xl bg-cb-primary text-white">Confirmer</button>
      </div>
    </form>
  </div>

  <!-- Communiquer aux passagers -->
  <div x-data="{ open: false }" @open-modal.window="if($event.detail==='communicate') open = true" x-show="open" x-cloak
       class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4" @click.self="open = false">
    <form method="post" action="<?= e(url('voyages/'.$trip['id'].'/communicate')) ?>" class="bg-white rounded-2xl p-6 max-w-md w-full" @click.stop>
