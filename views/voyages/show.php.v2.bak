      <div class="flex justify-end gap-2 mt-4">
        <button type="button" @click="open=false" class="px-4 py-2 rounded-xl border border-slate-200">Annuler</button>
        <button class="px-4 py-2 rounded-xl bg-cb-primary text-white">Confirmer</button>
      </div>
    </form>
  </div>
  <?php endif ?>

  <!-- Remplacer chauffeur -->
  <?php if (can('voyages.replace_driver')): ?>
  <div x-data="{ open: false }" @open-modal.window="if($event.detail==='replace-driver') open = true" x-show="open" x-cloak
       class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4" @click.self="open = false">
    <form method="post" action="<?= e(url('voyages/'.$trip['id'].'/replace-driver')) ?>" class="bg-white rounded-2xl p-6 max-w-md w-full" @click.stop>
      <?= csrf_field() ?>
      <h3 class="font-bold text-lg mb-4">Remplacer le chauffeur</h3>
      <input type="number" name="new_driver_id" required placeholder="ID du nouveau chauffeur" class="cb-input w-full mb-3">
      <textarea name="reason" rows="3" required minlength="5" placeholder="Motif (5 car. min)" class="cb-input w-full"></textarea>
      <div class="flex justify-end gap-2 mt-4">
        <button type="button" @click="open=false" class="px-4 py-2 rounded-xl border border-slate-200">Annuler</button>
        <button class="px-4 py-2 rounded-xl bg-cb-primary text-white">Confirmer</button>
      </div>
    </form>
  </div>
  <?php endif ?>

  <!-- Déverrouiller manifeste -->
  <?php if (can('voyages.unlock_manifest')): ?>
  <div x-data="{ open: false }" @open-modal.window="if($event.detail==='unlock') open = true" x-show="open" x-cloak
       class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4" @click.self="open = false">
    <form method="post" action="<?= e(url('voyages/'.$trip['id'].'/unlock')) ?>" class="bg-white rounded-2xl p-6 max-w-md w-full" @click.stop>
      <?= csrf_field() ?>
      <h3 class="font-bold text-lg mb-4">Déverrouiller le manifeste</h3>
      <p class="text-xs text-slate-500 mb-3">Cette action permettra à nouveau la vente de tickets pour ce voyage.</p>
      <textarea name="reason" rows="3" required minlength="5" placeholder="Motif (5 car. min)" class="cb-input w-full"></textarea>
      <div class="flex justify-end gap-2 mt-4">
        <button type="button" @click="open=false" class="px-4 py-2 rounded-xl border border-slate-200">Annuler</button>
        <button class="px-4 py-2 rounded-xl bg-amber-600 text-white">Déverrouiller</button>
      </div>
    </form>
  </div>
  <?php endif ?>

  <!-- Voyage de remplacement -->
  <?php if (can('voyages.create')): ?>
  <div x-data="{ open: false }" @open-modal.window="if($event.detail==='replacement') open = true" x-show="open" x-cloak
       class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4" @click.self="open = false">
    <form method="post" action="<?= e(url('voyages/'.$trip['id'].'/replacement')) ?>" class="bg-white rounded-2xl p-6 max-w-md w-full" @click.stop>
      <?= csrf_field() ?>
      <h3 class="font-bold text-lg mb-4">Créer un voyage de remplacement</h3>
      <p class="text-xs text-slate-500 mb-3">Clone ce voyage en gardant la ligne. Les billets resteront sur le voyage parent.</p>
      <div class="grid grid-cols-2 gap-3">
        <div><label class="cb-label">Date</label><input type="date" name="trip_date" value="<?= date('Y-m-d') ?>" required class="cb-input"></div>
        <div><label class="cb-label">Heure départ</label><input type="time" name="departure_scheduled" required class="cb-input"></div>
      </div>
      <div class="flex justify-end gap-2 mt-4">
        <button type="button" @click="open=false" class="px-4 py-2 rounded-xl border border-slate-200">Annuler</button>
        <button class="px-4 py-2 rounded-xl bg-cb-primary text-white">Créer</button>
      </div>
    </form>
  </div>
  <?php endif ?>

</div>
<?php $view->end() ?>
