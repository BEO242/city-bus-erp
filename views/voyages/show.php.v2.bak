          <i data-lucide="printer" class="w-4 h-4"></i> Manifeste
        </a>
        <?php if (can('voyages.edit') && !Trip::isTerminal($trip['status'])): ?>
          <a href="<?= e(url('voyages/'.$trip['id'].'/edit')) ?>"
             class="px-3 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 inline-flex items-center gap-2 text-sm">
            <i data-lucide="pencil" class="w-4 h-4"></i> Modifier
          </a>
        <?php endif ?>

        <!-- Menu actions plus -->
        <div class="relative">
          <button @click="actions = !actions"
                  class="px-3 py-2.5 rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-50 inline-flex items-center gap-2 text-sm">
            <i data-lucide="more-horizontal" class="w-4 h-4"></i> Actions
          </button>
          <div x-show="actions" @click.outside="actions = false" x-cloak
               class="absolute right-0 top-12 w-64 bg-white rounded-xl border border-slate-100 shadow-xl z-30 py-1 text-sm">
            <?php if (can('voyages.communicate') && !Trip::isTerminal($trip['status'])): ?>
              <button @click="$dispatch('open-modal','communicate'); actions=false" class="w-full text-left px-4 py-2.5 hover:bg-cb-bg/40 flex items-center gap-2">
                <i data-lucide="message-circle" class="w-4 h-4 text-cb-primary"></i> Communiquer aux passagers
              </button>
            <?php endif ?>
            <?php if (can('voyages.replace_bus') && in_array($trip['status'], ['planifie','valide','embarquement','en_route','incident'], true)): ?>
              <button @click="$dispatch('open-modal','replace-bus'); actions=false" class="w-full text-left px-4 py-2.5 hover:bg-cb-bg/40 flex items-center gap-2">
                <i data-lucide="truck" class="w-4 h-4 text-cb-primary"></i> Changer le bus
              </button>
            <?php endif ?>
            <?php if (can('voyages.replace_driver') && in_array($trip['status'], ['planifie','valide','embarquement','en_route','incident'], true)): ?>
              <button @click="$dispatch('open-modal','replace-driver'); actions=false" class="w-full text-left px-4 py-2.5 hover:bg-cb-bg/40 flex items-center gap-2">
                <i data-lucide="user" class="w-4 h-4 text-cb-primary"></i> Changer le chauffeur
              </button>
            <?php endif ?>
            <?php if ($manifestLocked && can('voyages.unlock_manifest')): ?>
              <button @click="$dispatch('open-modal','unlock'); actions=false" class="w-full text-left px-4 py-2.5 hover:bg-cb-bg/40 flex items-center gap-2">
                <i data-lucide="unlock" class="w-4 h-4 text-cb-primary"></i> Déverrouiller manifeste
              </button>
            <?php elseif (can('voyages.lock_manifest')): ?>
              <form method="post" action="<?= e(url('voyages/'.$trip['id'].'/lock')) ?>">
                <?= csrf_field() ?>
                <button type="submit" class="w-full text-left px-4 py-2.5 hover:bg-cb-bg/40 flex items-center gap-2">
                  <i data-lucide="lock" class="w-4 h-4 text-cb-primary"></i> Verrouiller manifeste
                </button>
              </form>
            <?php endif ?>
            <?php if (in_array($trip['status'], ['incident','retourne'], true) && can('voyages.create')): ?>
              <button @click="$dispatch('open-modal','replacement'); actions=false" class="w-full text-left px-4 py-2.5 hover:bg-cb-bg/40 flex items-center gap-2">
                <i data-lucide="copy" class="w-4 h-4 text-cb-primary"></i> Créer un voyage de remplacement
              </button>
            <?php endif ?>
            <div class="border-t border-slate-100 my-1"></div>
            <?php if (!Trip::isTerminal($trip['status'])): ?>
              <button @click="$dispatch('open-modal','status'); actions=false" class="w-full text-left px-4 py-2.5 hover:bg-cb-bg/40 flex items-center gap-2">
                <i data-lucide="git-branch" class="w-4 h-4 text-cb-primary"></i> Changer le statut
              </button>
            <?php endif ?>
            <?php if (can('voyages.delete')): ?>
              <form method="post" action="<?= e(url('voyages/'.$trip['id'].'/delete')) ?>" onsubmit="return confirm('Supprimer définitivement ce voyage ?')">
