                <td class="num text-right"><?= e(fcfa((int)$tk['price_fcfa'])) ?></td>
                <td><span class="cockpit-status <?= match($tk['status'] ?? '') {'emis'=>'amber','controle','utilise'=>'green','annule'=>'red',default=>'slate'} ?>"><?= e($tk['status'] ?? '') ?></span></td>
              </tr>
            <?php endforeach ?>
          </tbody>
