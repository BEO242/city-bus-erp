        <table class="cockpit-table w-full">
          <thead>
            <tr><th>N° ticket</th><th>Siège</th><th>Passager</th><th>Téléphone</th><th>Embarq.</th><th>Descente</th><th class="text-right">Prix</th><th>Statut</th></tr>
