<?php
/** @var \CityBus\Core\View $view */
$view->extends('layouts/app');
use CityBus\Models\Trip;

$isEdit = !empty($trip);
$action = $isEdit ? url('voyages/' . $trip['id'] . '/update') : url('voyages');
$decoded = function ($v) {
    if (!$v) return [];
    $j = json_decode((string)$v, true);
    return is_array($j) ? $j : [(string)$v];
};
$notesArr   = $isEdit ? $decoded($trip['notes'] ?? null) : [];
$incNotesArr= $isEdit ? $decoded($trip['incident_notes'] ?? null) : [];
?>
<?php $view->start('content') ?>
<div class="space-y-5" x-data='{
  notes: <?= htmlspecialchars(json_encode($notesArr ?: [""], JSON_UNESCAPED_UNICODE), ENT_QUOTES) ?>,
  incNotes: <?= htmlspecialchars(json_encode($incNotesArr ?: [], JSON_UNESCAPED_UNICODE), ENT_QUOTES) ?>,
  crew: <?= htmlspecialchars(json_encode(array_map(fn($c) => ['emp' => $c['emp_id'], 'role' => $c['role'], 'note' => $c['crew_note']], $crew ?: []), JSON_UNESCAPED_UNICODE), ENT_QUOTES) ?>,
  selectedLine: <?= $isEdit ? (int)$trip['line_id'] : 0 ?>,
  selectedBus: <?= $isEdit ? (int)$trip['bus_id'] : 0 ?>,
  selectedDriver: <?= $isEdit ? (int)$trip['driver_id'] : 0 ?>
}'>

  <!-- Fil d'Ariane -->
  <div class="flex items-center gap-2 text-sm text-slate-500">
    <a href="<?= e(url('voyages')) ?>" class="hover:text-cb-primary inline-flex items-center gap-1">
      <i data-lucide="chevron-left" class="w-4 h-4"></i> Voyages
    </a>
    <span>/</span>
    <span class="text-slate-800 font-semibold"><?= e($title) ?></span>
  </div>

  <form method="post" action="<?= e($action) ?>" data-dirty-watch="<?= $isEdit ? '1' : '0' ?>" class="space-y-5">
    <?= csrf_field() ?>

    <!-- Bloc 1 : Affectations principales -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
        <i data-lucide="truck" class="w-5 h-5 text-cb-primary"></i> Affectation
      </h2>

      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <label class="cb-label">Ligne *</label>
          <select name="line_id" required x-model="selectedLine" class="cb-input w-full">
            <option value="">— Sélectionner —</option>
            <?php foreach ($lines as $l): ?>
              <option value="<?= (int)$l['id'] ?>" <?= ($isEdit && (int)$trip['line_id']===(int)$l['id'])?'selected':'' ?>>
                <?= e($l['code']) ?> · <?= e($l['name']) ?>
                (<?= e($l['departure_city_name']) ?> → <?= e($l['arrival_city_name']) ?>)
              </option>
            <?php endforeach ?>
          </select>
          <?php foreach (errors('line_id') as $err): ?><p class="text-xs text-rose-600 mt-1"><?= e($err) ?></p><?php endforeach ?>
        </div>

        <div>
          <label class="cb-label">Bus *</label>
          <select name="bus_id" required x-model="selectedBus" class="cb-input w-full">
            <option value="">— Sélectionner —</option>
            <?php foreach ($buses as $b): ?>
              <option value="<?= (int)$b['id'] ?>" <?= ($isEdit && (int)$trip['bus_id']===(int)$b['id'])?'selected':'' ?>>
                <?= e($b['code']) ?> · <?= e($b['plate']) ?> (<?= (int)$b['seats'] ?> places)
              </option>
            <?php endforeach ?>
          </select>
          <p class="text-xs text-slate-400 mt-1">Bus en maintenance / hors service exclus.</p>
        </div>

        <div>
          <label class="cb-label">Chauffeur *</label>
          <select name="driver_id" required x-model="selectedDriver" class="cb-input w-full">
            <option value="">— Sélectionner —</option>
            <?php foreach ($drivers as $d): ?>
              <option value="<?= (int)$d['id'] ?>" <?= ($isEdit && (int)$trip['driver_id']===(int)$d['id'])?'selected':'' ?>>
                <?= e($d['matricule']) ?> · <?= e($d['first_name']) ?> <?= e($d['last_name']) ?>
              </option>
            <?php endforeach ?>
          </select>
          <p class="text-xs text-slate-400 mt-1">Validation HOS automatique au départ.</p>
        </div>
      </div>
    </div>

    <!-- Bloc 2 : Planning -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
        <i data-lucide="calendar" class="w-5 h-5 text-cb-primary"></i> Planning
      </h2>

      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <label class="cb-label">Date *</label>
          <input type="date" name="trip_date" required value="<?= e($isEdit ? $trip['trip_date'] : date('Y-m-d')) ?>" class="cb-input w-full">
        </div>
        <div>
          <label class="cb-label">Heure départ *</label>
          <input type="time" name="departure_scheduled" required value="<?= e($isEdit ? substr($trip['departure_scheduled'], 0, 5) : '') ?>" class="cb-input w-full">
        </div>
        <div>
          <label class="cb-label">Heure arrivée prévue</label>
          <input type="time" name="arrival_scheduled" value="<?= e($isEdit && $trip['arrival_scheduled'] ? substr($trip['arrival_scheduled'], 0, 5) : '') ?>" class="cb-input w-full">
        </div>

        <?php if ($isEdit): ?>
          <div>
            <label class="cb-label">Départ réel</label>
            <input type="time" name="departure_actual" value="<?= e($trip['departure_actual'] ? substr($trip['departure_actual'], 0, 5) : '') ?>" class="cb-input w-full">
          </div>
          <div>
            <label class="cb-label">Arrivée réelle</label>
            <input type="time" name="arrival_actual" value="<?= e($trip['arrival_actual'] ? substr($trip['arrival_actual'], 0, 5) : '') ?>" class="cb-input w-full">
          </div>
        <?php endif ?>
      </div>
    </div>

    <!-- Bloc 3 : Type & priorité -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <h2 class="font-bold text-slate-800 mb-4 flex items-center gap-2">
        <i data-lucide="tags" class="w-5 h-5 text-cb-primary"></i> Caractéristiques
      </h2>
      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <label class="cb-label">Type de voyage</label>
          <select name="trip_type" class="cb-input w-full">
            <?php foreach (Trip::TYPES as $k => $lbl): ?>
              <option value="<?= e($k) ?>" <?= ($isEdit && $trip['trip_type']===$k)?'selected':'' ?>><?= e($lbl) ?></option>
            <?php endforeach ?>
          </select>
        </div>
        <div>
          <label class="cb-label">Priorité</label>
          <select name="priority" class="cb-input w-full">
            <?php foreach (Trip::PRIORITIES as $k => $lbl): ?>
              <option value="<?= e($k) ?>" <?= ($isEdit && $trip['priority']===$k)?'selected':'' ?>><?= e($lbl) ?></option>
            <?php endforeach ?>
          </select>
        </div>
        <div>
          <label class="cb-label">Référence externe</label>
          <input name="external_reference" value="<?= e($isEdit ? ($trip['external_reference'] ?? '') : '') ?>" placeholder="Bon de commande, agréeur…" class="cb-input w-full">
        </div>
        <div class="md:col-span-3">
          <label class="flex items-center gap-2">
            <input type="checkbox" name="public_visible" value="1" <?= (!$isEdit || (int)$trip['public_visible'])?'checked':'' ?> class="w-4 h-4">
            <span class="text-sm">Visible sur le site public</span>
          </label>
        </div>
      </div>
    </div>

    <!-- Bloc 4 : Kilométrage / météo -->
    <details class="bg-white rounded-2xl border border-slate-100 shadow-soft" <?= $isEdit ? 'open' : '' ?>>
      <summary class="px-6 py-4 cursor-pointer font-bold text-slate-800 flex items-center gap-2">
        <i data-lucide="gauge" class="w-5 h-5 text-cb-primary"></i> Kilométrage / Météo
      </summary>
      <div class="p-6 pt-0 grid md:grid-cols-3 gap-4">
        <div>
          <label class="cb-label">Km au départ</label>
          <input type="number" name="mileage_start" value="<?= e($isEdit ? ($trip['mileage_start'] ?? '') : '') ?>" class="cb-input w-full">
        </div>
        <?php if ($isEdit): ?>
          <div>
            <label class="cb-label">Km à l'arrivée</label>
            <input type="number" name="mileage_end" value="<?= e($trip['mileage_end'] ?? '') ?>" class="cb-input w-full">
          </div>
        <?php endif ?>
        <div>
          <label class="cb-label">Conditions météo</label>
          <input name="weather_conditions" value="<?= e($isEdit ? ($trip['weather_conditions'] ?? '') : '') ?>" placeholder="Ensoleillé, pluie…" class="cb-input w-full">
        </div>
        <div>
          <label class="cb-label">Température (°C)</label>
          <input type="number" name="weather_temp_celsius" value="<?= e($isEdit ? ($trip['weather_temp_celsius'] ?? '') : '') ?>" class="cb-input w-full">
        </div>
      </div>
    </details>

    <!-- Bloc 5 : Équipage -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="users" class="w-5 h-5 text-cb-primary"></i> Équipage supplémentaire
        </h2>
        <button type="button" @click="crew.push({emp:'', role:'convoyeur', note:''})" class="text-xs text-cb-primary hover:underline">+ Ajouter membre</button>
      </div>
      <template x-for="(c, idx) in crew" :key="idx">
        <div class="grid md:grid-cols-12 gap-2 mb-2 items-center">
          <select :name="'crew_employee_id[]'" x-model="c.emp" class="cb-input md:col-span-5 text-sm">
            <option value="">— Membre —</option>
            <?php foreach ($staff as $s): ?>
              <option value="<?= (int)$s['id'] ?>"><?= e($s['matricule']) ?> · <?= e($s['first_name']) ?> <?= e($s['last_name']) ?> (<?= e($s['position']) ?>)</option>
            <?php endforeach ?>
          </select>
          <select :name="'crew_role[]'" x-model="c.role" class="cb-input md:col-span-2 text-sm">
            <option value="chauffeur">Chauffeur (relève)</option>
            <option value="convoyeur">Convoyeur</option>
            <option value="caissier">Caissier</option>
            <option value="controleur">Contrôleur</option>
            <option value="guide">Guide</option>
            <option value="autre">Autre</option>
          </select>
          <input :name="'crew_notes[]'" x-model="c.note" placeholder="Notes" class="cb-input md:col-span-4 text-sm">
          <button type="button" @click="crew.splice(idx, 1)" class="text-rose-600 text-sm hover:underline md:col-span-1">Supprimer</button>
        </div>
      </template>
    </div>

    <!-- Bloc 6 : Notes -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-soft p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-bold text-slate-800 flex items-center gap-2">
          <i data-lucide="sticky-note" class="w-5 h-5 text-cb-primary"></i> Notes
        </h2>
        <button type="button" @click="notes.push('')" class="text-xs text-cb-primary hover:underline">+ Ligne</button>
      </div>
      <template x-for="(n, idx) in notes" :key="idx">
        <div class="flex gap-2 mb-2">
          <input :name="'notes[]'" x-model="notes[idx]" class="cb-input flex-1 text-sm">
          <button type="button" @click="notes.splice(idx,1)" class="text-rose-600 text-sm">×</button>
        </div>
      </template>

      <?php if ($isEdit): ?>
        <div class="mt-6 pt-6 border-t border-slate-100">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-rose-700 flex items-center gap-2">
              <i data-lucide="alert-triangle" class="w-4 h-4"></i> Notes d'incident
            </h3>
            <button type="button" @click="incNotes.push('')" class="text-xs text-rose-600 hover:underline">+ Ligne</button>
          </div>
          <template x-for="(n, idx) in incNotes" :key="idx">
            <div class="flex gap-2 mb-2">
              <input :name="'incident_notes[]'" x-model="incNotes[idx]" class="cb-input flex-1 text-sm border-rose-200">
              <button type="button" @click="incNotes.splice(idx,1)" class="text-rose-600 text-sm">×</button>
            </div>
          </template>
        </div>
      <?php endif ?>
    </div>

    <!-- Submit -->
    <div class="flex justify-end gap-2">
      <a href="<?= e(url($isEdit ? 'voyages/'.$trip['id'] : 'voyages')) ?>" class="px-5 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50">Annuler</a>
      <button data-dirty-submit class="px-6 py-2.5 rounded-xl bg-cb-primary text-white font-semibold inline-flex items-center gap-2 hover:bg-cb-dark shadow-soft">
        <i data-lucide="<?= $isEdit ? 'save' : 'plus' ?>" class="w-4 h-4"></i>
        <?= $isEdit ? 'Enregistrer les modifications' : 'Créer le voyage' ?>
      </button>
    </div>
  </form>
</div>
<?php $view->end() ?>
