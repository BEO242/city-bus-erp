                  <i data-lucide="armchair" class="w-3 h-3"></i><?= $sold ?> / <?= $seats ?> places
                </span>
                <span class="font-bold <?= $pct >= 80 ? 'text-emerald-600' : ($pct >= 50 ? 'text-amber-600' : 'text-slate-600') ?>"><?= $pct ?>%</span>
              </div>
              <div class="h-1.5 rounded-full bg-slate-100">
                <div class="h-full rounded-full transition-all <?= $pct >= 80 ? 'bg-emerald-500' : ($pct >= 50 ? 'bg-amber-400' : 'bg-cb-primary') ?>" style="width:<?= $pct ?>%"></div>
              </div>
              <div class="flex items-center justify-between mt-2 text-xs">
                <?php if ($rev > 0): ?>
                  <span class="text-emerald-600 font-semibold flex items-center gap-1">
                    <i data-lucide="banknote" class="w-3 h-3"></i><?= e(fcfa($rev)) ?>
                  </span>
                <?php else: ?>
                  <span></span>
                <?php endif ?>
                <?php if (!empty($t['parcels_count']) && (int)$t['parcels_count'] > 0): ?>
                  <span class="text-slate-500 flex items-center gap-1">
                    <i data-lucide="package" class="w-3 h-3"></i><?= (int)$t['parcels_count'] ?> colis
                  </span>
                <?php endif ?>
              </div>
            </div>
          </div>
        </a>
      <?php endforeach ?>
    </div>

  <?php endif ?>

  <!-- ── Pagination ───────────────────────────────── -->
  <?php if ($lastPage > 1): ?>
    <div class="flex items-center justify-between bg-white rounded-xl border border-slate-100 p-3">
      <span class="text-xs text-slate-500">
        Page <?= $page ?> sur <?= $lastPage ?> · <?= (int)$total ?> voyage(s)
      </span>
      <div class="flex gap-1">
        <?php if ($page > 1): ?>
          <a href="?<?= e($qs(['page' => 1])) ?>" class="px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs hover:bg-slate-50">«</a>
          <a href="?<?= e($qs(['page' => $page - 1])) ?>" class="px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs hover:bg-slate-50">‹</a>
        <?php endif ?>
        <span class="px-3 py-1.5 rounded-lg bg-cb-primary text-white text-xs font-semibold"><?= $page ?></span>
        <?php if ($page < $lastPage): ?>
          <a href="?<?= e($qs(['page' => $page + 1])) ?>" class="px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs hover:bg-slate-50">›</a>
          <a href="?<?= e($qs(['page' => $lastPage])) ?>" class="px-2.5 py-1.5 rounded-lg border border-slate-200 text-xs hover:bg-slate-50">»</a>
        <?php endif ?>
      </div>
    </div>
  <?php endif ?>
</div>
<?php $view->end() ?>
