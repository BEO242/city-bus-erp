<?php
/** @var \CityBus\Core\View $view */
$view->extends('layouts/app');
use CityBus\Models\Trip;

$statusMeta = [
  'planifie'     => ['label'=>'Planifié',    'cls'=>'bg-slate-100 text-slate-600 border-slate-200',         'icon'=>'clock',        'dot'=>'bg-slate-400'],
  'valide'       => ['label'=>'Validé',      'cls'=>'bg-cyan-50 text-cyan-700 border-cyan-200',             'icon'=>'check',        'dot'=>'bg-cyan-500'],
  'embarquement' => ['label'=>'Embarquement','cls'=>'bg-amber-50 text-amber-700 border-amber-200',          'icon'=>'users',        'dot'=>'bg-amber-400'],
  'en_route'     => ['label'=>'En route',    'cls'=>'bg-cb-primary text-white border-cb-primary',           'icon'=>'navigation',   'dot'=>'bg-white'],
  'arrive'       => ['label'=>'Arrivé',      'cls'=>'bg-emerald-50 text-emerald-700 border-emerald-200',    'icon'=>'map-pin',      'dot'=>'bg-emerald-500'],
  'cloture'      => ['label'=>'Clôturé',     'cls'=>'bg-emerald-100 text-emerald-800 border-emerald-300',   'icon'=>'check-circle', 'dot'=>'bg-emerald-600'],
  'incident'     => ['label'=>'Incident',    'cls'=>'bg-rose-50 text-rose-700 border-rose-200',             'icon'=>'alert-triangle','dot'=>'bg-rose-500'],
  'retourne'     => ['label'=>'Retourné',    'cls'=>'bg-orange-50 text-orange-700 border-orange-200',       'icon'=>'undo-2',       'dot'=>'bg-orange-500'],
  'litige'       => ['label'=>'Litige',      'cls'=>'bg-purple-50 text-purple-700 border-purple-200',       'icon'=>'gavel',        'dot'=>'bg-purple-500'],
  'annule'       => ['label'=>'Annulé',      'cls'=>'bg-rose-50 text-rose-600 border-rose-200',             'icon'=>'x-circle',     'dot'=>'bg-rose-400'],
];
$priorityMeta = [
  'normale' => ['label'=>'','cls'=>''],
  'vip'     => ['label'=>'VIP','cls'=>'bg-purple-100 text-purple-700'],
  'express' => ['label'=>'Express','cls'=>'bg-cb-bg text-cb-primary'],
  'convoi'  => ['label'=>'Convoi','cls'=>'bg-slate-200 text-slate-700'],
];

$tolerance = (int)\CityBus\Core\Setting::getInt('voyage.delay_tolerance_minutes', 15);
$otpPct = ((int)($kpiRow['done_count'] ?? 0)) > 0
  ? round(((int)($kpiRow['otp_count'] ?? 0)) / max(1,(int)($kpiRow['done_count'] ?? 0)) * 100, 1)
  : null;
$avgDelay = $kpiRow['avg_delay'] !== null ? round((float)$kpiRow['avg_delay'], 1) : null;

$qs = function (array $merge = []) {
  return http_build_query(array_filter(array_merge($_GET, $merge), fn($v) => $v !== '' && $v !== null));
};

$activeScope = $scope ?? '';
$scopeChips = [
  ''            => 'Tous',
  'today'       => "Aujourd'hui",
  'tomorrow'    => 'Demain',
  'week'        => 'Cette semaine',
  'in_progress' => 'En cours',
  'to_close'    => 'À clôturer',
];
?>
<?php $view->start('content') ?>
