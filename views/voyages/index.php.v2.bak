              <td><?= e(trim(($t['driver_first'] ?? '') . ' ' . ($t['driver_last'] ?? ''))) ?: '—' ?></td>
              <td><span class="cockpit-status <?= match($t['status']) {'en_route'=>'amber','cloture','arrive'=>'green','annule','incident'=>'red',default=>'slate'} ?>"><?= e($sm['label']) ?></span></td>
              <td class="num text-right <?= $delay > $tolerance ? 'text-red' : ($delay > 0 ? 'text-amber' : 'text-faint') ?>">
                <?= $delay ? '+' . $delay : '—' ?>
              </td>
              <td class="num text-right"><?= $sold ?>/<?= $seats ?></td>
              <td class="num text-right <?= $occ >= 80 ? 'text-green' : ($occ >= 50 ? 'text-amber' : '') ?>"><?= $occ ?>%</td>
              <td class="num text-right"><?= e(fcfa((int)$t['revenue'])) ?></td>
              <td class="num text-right text-faint"><?= (int)($t['parcels_count'] ?? 0) ?></td>
