<?php
/** @var \CityBus\Core\View $view */
$view->extends('layouts/app');

$_errors = errors();
$_old    = fn(string $f, mixed $d = '') => old($f, $d);
$isEdit  = !empty($trip);
$action  = $isEdit ? url('voyages/'.$trip['id'].'/update') : url('voyages');
$dateVal = fn($v) => ($v && $v !== '0000-00-00') ? $v : '';

// Grouper arrêts par ligne pour injection JS
$_stopsByLine = [];
foreach ($stops as $s) {
    $_stopsByLine[(int)$s['line_id']][] = ['id'=>(int)$s['id'],'name'=>$s['name'],'km_from_origin'=>$s['km_from_origin'],'order_position'=>(int)$s['order_position']];
}

// Préparer l'équipage existant pour Alpine
$_crewInit = [];
foreach ($crew as $c) {
    $_crewInit[] = [
        'employee_id' => (int)$c['emp_id'],
        'role'        => $c['role'],
        'notes'       => $c['crew_note'] ?? '',
    ];
}

// Préparer notes internes (JSON ou texte plain pour rétro-compat)
$_decodeList = function(?string $v): array {
    if (!$v) return [];
    $d = json_decode($v, true);
    return is_array($d) ? array_values(array_filter($d)) : [$v];
};
// Sur erreur de validation, old('notes') retourne un tableau directement
$_notesInit    = is_array($_old('notes'))          ? array_values(array_filter($_old('notes')))
                                                    : $_decodeList($trip['notes'] ?? null);
$_incidentInit = $_decodeList($trip['incident_notes'] ?? null);

$_tabWithError = 'trajet';
if (isset($_errors['driver_id'])) $_tabWithError = 'equipe';
if (isset($_errors['notes']))     $_tabWithError = 'notes';
?>
<?php $view->start('content') ?>
