    <!-- ── Barre d'actions ─────────────────────────────────────────── -->
    <div class="border-t border-slate-100 bg-slate-50 px-6 py-4 flex items-center justify-between gap-3">
      <a href="<?= e($isEdit ? url('voyages/'.$trip['id']) : url('voyages')) ?>"
         class="px-5 py-2.5 rounded-xl border border-slate-200 text-slate-600 hover:bg-slate-100 transition text-sm font-medium inline-flex items-center gap-2">
        <i data-lucide="x" class="w-4 h-4"></i> Annuler
      </a>
      <div class="flex items-center gap-3">
        <button type="button" x-show="tab === 'trajet'" @click="tab = 'equipe'"
                class="px-5 py-2.5 rounded-xl border border-cb-primary text-cb-primary hover:bg-cb-bg transition text-sm font-semibold inline-flex items-center gap-2">
          Suivant <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
        <button type="button" x-show="tab === 'equipe'" @click="tab = 'horaires'"
                class="px-5 py-2.5 rounded-xl border border-cb-primary text-cb-primary hover:bg-cb-bg transition text-sm font-semibold inline-flex items-center gap-2">
          Suivant <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
        <button type="button" x-show="tab === 'horaires'" @click="tab = 'notes'"
                class="px-5 py-2.5 rounded-xl border border-cb-primary text-cb-primary hover:bg-cb-bg transition text-sm font-semibold inline-flex items-center gap-2">
          Suivant <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </button>
        <button type="submit" data-dirty-submit
                class="px-6 py-2.5 rounded-xl bg-cb-primary text-white font-bold hover:bg-cb-dark transition shadow-soft inline-flex items-center gap-2">
          <i data-lucide="check" class="w-4 h-4"></i>
          <?= $isEdit ? 'Enregistrer les modifications' : 'Créer le voyage' ?>
        </button>
      </div>
    </div>
  </form>
</div>

<script>
const STOPS_BY_LINE = <?= json_encode($_stopsByLine) ?>;

function voyageForm() {
  return {
    tab: '<?= $_tabWithError ?>',
    selectedLineId: '<?= e((string)($_old('line_id', $trip['line_id'] ?? ''))) ?>',
    lineInfo: { code:'', dep:'', arr:'', dist:'', dur:'' },
    lineStops: [],
    crew: <?= json_encode($_crewInit) ?>,
    notes: <?= json_encode($_notesInit) ?>,
    incidents: <?= json_encode($_incidentInit) ?>,

    init() {
      if (this.selectedLineId) this.onLineChange();
      this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
    },

    onLineChange() {
      const sel = document.getElementById('line_id');
      const opt = sel ? sel.options[sel.selectedIndex] : null;
      if (opt && opt.value) {
        this.lineInfo = { code: opt.value, dep: opt.dataset.dep||'', arr: opt.dataset.arr||'', dist: opt.dataset.dist||'', dur: opt.dataset.dur||'' };
        this.lineStops = STOPS_BY_LINE[opt.value] || [];
      } else {
        this.lineInfo = { code:'', dep:'', arr:'', dist:'', dur:'' };
        this.lineStops = [];
      }
      this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
    },

    addCrew() {
      this.crew.push({ employee_id: '', role: 'convoyeur', notes: '' });
      this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); });
    },

    removeCrew(idx) { this.crew.splice(idx, 1); },

    addNote() { this.notes.push(''); this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }); },
    removeNote(idx) { this.notes.splice(idx, 1); },

    addIncident() { this.incidents.push(''); this.$nextTick(() => { if (typeof lucide !== 'undefined') lucide.createIcons(); }); },
    removeIncident(idx) { this.incidents.splice(idx, 1); },
  };
}
</script>
<?php $view->end() ?>
