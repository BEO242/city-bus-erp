            <?php foreach ($crew as $m): ?>
            <?php
              $roleLabels = ['chauffeur'=>'Chauffeur (relève)','convoyeur'=>'Convoyeur','caissier'=>'Caissier','controleur'=>'Contrôleur','guide'=>'Guide','autre'=>'Autre'];
              $roleCls    = ['chauffeur'=>'bg-cb-bg text-cb-primary','convoyeur'=>'bg-slate-100 text-slate-600','caissier'=>'bg-blue-50 text-blue-700','controleur'=>'bg-purple-50 text-purple-700','guide'=>'bg-teal-50 text-teal-700','autre'=>'bg-slate-100 text-slate-500'];
            ?>
            <div class="flex items-center gap-4 p-4 rounded-2xl border border-slate-100 hover:bg-slate-50 transition">
              <div class="w-10 h-10 rounded-xl bg-slate-100 text-slate-600 flex items-center justify-center shrink-0 font-bold text-sm">
                <?= e(mb_strtoupper(mb_substr($m['first_name'],0,1).mb_substr($m['last_name'],0,1))) ?>
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-semibold text-slate-900 truncate"><?= e($m['first_name'].' '.$m['last_name']) ?></div>
                <div class="text-xs text-slate-500 flex items-center gap-2 mt-0.5">
                  <span><?= e($m['matricule'] ?? '') ?></span>
                  <?php if (!empty($m['phone'])): ?>
                    <span class="flex items-center gap-1"><i data-lucide="phone" class="w-3 h-3"></i><?= e($m['phone']) ?></span>
                  <?php endif ?>
                  <?php if (!empty($m['crew_note'])): ?>
                    <span class="italic text-slate-400">&mdash; <?= e($m['crew_note']) ?></span>
                  <?php endif ?>
                </div>
              </div>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold shrink-0
                           <?= $roleCls[$m['role']] ?? 'bg-slate-100 text-slate-600' ?>">
                <?= $roleLabels[$m['role']] ?? $m['role'] ?>
              </span>
            </div>
            <?php endforeach ?>
          </div>
        </div>
        <?php else: ?>
          <div class="text-center py-10">
            <i data-lucide="user-plus" class="w-10 h-10 mx-auto text-slate-200 mb-2"></i>
            <p class="text-slate-400 text-sm">Aucun équipage supplémentaire enregistré.</p>
            <?php if (can('voyages.edit')): ?>
            <a href="<?= e(url('voyages/'.$trip['id'].'/edit')) ?>"
               class="mt-3 inline-flex items-center gap-1.5 text-sm text-cb-primary font-semibold hover:text-cb-dark transition">
              <i data-lucide="plus" class="w-4 h-4"></i> Ajouter des membres
            </a>
            <?php endif ?>
          </div>
        <?php endif ?>
      </div>

      <!-- ═══ Onglet PLAN DES SIÈGES ══════════════════════════════════ -->
      <div x-show="tab === 'siege'" x-transition>
        <div class="max-w-2xl mx-auto">
          <!-- Légende -->
          <div class="flex gap-6 justify-center mb-6 flex-wrap text-sm">
            <span class="flex items-center gap-2"><span class="w-4 h-4 rounded border-2 bg-emerald-50 border-emerald-300"></span> Libre</span>
            <span class="flex items-center gap-2"><span class="w-4 h-4 rounded border-2 bg-rose-100 border-rose-300"></span> Occupé</span>
          </div>

          <!-- Représentation bus -->
          <div class="bg-slate-50 rounded-2xl border border-slate-200 p-5">
            <!-- Cabine chauffeur -->
            <div class="flex justify-end mb-4">
              <div class="bg-slate-200 text-slate-600 text-xs font-semibold px-4 py-1.5 rounded-full flex items-center gap-2">
                <i data-lucide="steering-wheel" class="w-3.5 h-3.5"></i> Chauffeur
              </div>
            </div>

            <!-- Grille 2+couloir+2 -->
            <?php
              $rows = (int)ceil($totalSeats / 4);
              $seat = 1;
            ?>
            <div class="space-y-2 max-w-xs mx-auto">
              <?php for ($row = 1; $row <= $rows; $row++): ?>
              <div class="grid grid-cols-5 gap-2 items-center">
                <?php
                  $seatL1 = $seat;
                  $seatL2 = $seat + 1;
                  $seatR1 = $seat + 2;
                  $seatR2 = $seat + 3;
                  $seat  += 4;

                  foreach ([$seatL1, $seatL2] as $s):
                    if ($s > $totalSeats): ?>
                      <div></div>
                    <?php else:
                      $bk = isset($booked[$s]);
                      $passenger = null;
                      foreach ($tickets as $t) {
                        if ((int)$t['seat_number'] === $s && $t['status'] !== 'annule') {
                          $passenger = $t['passenger_name'] ?? null; break;
                        }
                      }
                ?>
                <div title="<?= $passenger ? e($passenger) : 'Libre' ?>"
                     class="aspect-square rounded-lg border-2 flex items-center justify-center font-mono text-xs font-bold transition cursor-default
                            <?= $bk ? 'bg-rose-100 text-rose-700 border-rose-300' : 'bg-white text-slate-600 border-slate-200 hover:border-cb-primary' ?>">
                  <?= $s ?>
                </div>
                    <?php endif ?>
                  <?php endforeach ?>

                <!-- Couloir -->
                <div class="flex items-center justify-center">
                  <div class="h-px w-full bg-slate-200"></div>
                </div>

                <?php foreach ([$seatR1, $seatR2] as $s):
                    if ($s > $totalSeats): ?>
                      <div></div>
                    <?php else:
                      $bk = isset($booked[$s]);
                      $passenger = null;
                      foreach ($tickets as $t) {
                        if ((int)$t['seat_number'] === $s && $t['status'] !== 'annule') {
                          $passenger = $t['passenger_name'] ?? null; break;
                        }
                      }
                ?>
                <div title="<?= $passenger ? e($passenger) : 'Libre' ?>"
                     class="aspect-square rounded-lg border-2 flex items-center justify-center font-mono text-xs font-bold transition cursor-default
                            <?= $bk ? 'bg-rose-100 text-rose-700 border-rose-300' : 'bg-white text-slate-600 border-slate-200 hover:border-cb-primary' ?>">
                  <?= $s ?>
                </div>
                    <?php endif ?>
                <?php endforeach ?>
              </div>
              <?php endfor ?>
            </div>

            <!-- Arrière du bus -->
            <div class="flex justify-center mt-4">
              <div class="bg-slate-200 text-slate-500 text-xs px-4 py-1 rounded-full">— Arrière —</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ Onglet PASSAGERS ═════════════════════════════════════════ -->
      <div x-show="tab === 'passagers'" x-transition>
        <?php if (!$passengerTickets): ?>
          <div class="text-center py-12">
            <i data-lucide="users" class="w-10 h-10 mx-auto text-slate-200 mb-2"></i>
            <p class="text-slate-400 font-medium">Aucun passager enregistré</p>
          </div>
        <?php else: ?>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-100 text-left">
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Siège</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Ticket</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Passager</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Catégorie</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Classe</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide text-right">Prix</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Statut</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-50">
                <?php foreach ($passengerTickets as $t): ?>
                <tr class="hover:bg-slate-50 transition">
                  <td class="py-3 pr-4">
                    <?php if ($t['seat_number']): ?>
                    <span class="w-7 h-7 rounded-lg bg-cb-bg text-cb-primary font-bold text-xs flex items-center justify-center"><?= (int)$t['seat_number'] ?></span>
                    <?php else: ?>
                    <span class="text-slate-300">—</span>
                    <?php endif ?>
                  </td>
                  <td class="py-3 pr-4 font-mono text-xs text-slate-500"><?= e($t['ticket_number']) ?></td>
                  <td class="py-3 pr-4">
                    <div class="font-semibold text-slate-900"><?= e($t['passenger_name'] ?? '—') ?></div>
                    <?php if (!empty($t['passenger_phone'])): ?>
                      <div class="text-xs text-slate-400"><?= e($t['passenger_phone']) ?></div>
                    <?php endif ?>
                  </td>
                  <td class="py-3 pr-4 text-slate-600 capitalize"><?= e(str_replace('_',' ',$t['passenger_category'])) ?></td>
                  <td class="py-3 pr-4 text-slate-600 capitalize"><?= e(str_replace('_',' ',$t['travel_class'])) ?></td>
                  <td class="py-3 text-right font-semibold text-slate-900"><?= fcfa((int)$t['price_fcfa']) ?></td>
                  <td class="py-3 pl-4">
                    <span class="px-2 py-0.5 rounded-full text-xs font-semibold <?= $ticketStatusCls[$t['status']] ?? 'bg-slate-100 text-slate-600' ?>">
                      <?= e($t['status']) ?>
                    </span>
                  </td>
                </tr>
                <?php endforeach ?>
              </tbody>
              <tfoot>
                <tr class="border-t-2 border-slate-100">
                  <td colspan="5" class="pt-3 text-sm font-semibold text-slate-500">Total passagers</td>
                  <td class="pt-3 text-right font-bold text-emerald-600">
                  <?= fcfa(array_sum(array_column(array_values($passengerTickets), 'price_fcfa'))) ?>
                  </td>
                  <td></td>
                </tr>
              </tfoot>
            </table>
          </div>
        <?php endif ?>
      </div>

      <!-- ═══ Onglet BAGAGES ═══════════════════════════════════════════ -->
      <div x-show="tab === 'bagages'" x-transition>
        <?php if (!$baggageTickets): ?>
          <div class="text-center py-12">
            <i data-lucide="package" class="w-10 h-10 mx-auto text-slate-200 mb-2"></i>
            <p class="text-slate-400 font-medium">Aucun ticket bagage</p>
          </div>
        <?php else: ?>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-100 text-left">
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Ticket</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Type</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Passager</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide text-right">Prix</th>
                  <th class="pb-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Statut</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-50">
                <?php foreach ($baggageTickets as $t): ?>
                <tr class="hover:bg-slate-50 transition">
                  <td class="py-3 pr-4 font-mono text-xs text-slate-500"><?= e($t['ticket_number']) ?></td>
                  <td class="py-3 pr-4">
                    <?php
                      $typeLabel = $t['ticket_type'] === 'bagage_franchise' ? 'Franchise' : 'Excédent';
                      $typeCls   = $t['ticket_type'] === 'bagage_franchise'
                        ? 'bg-blue-50 text-blue-700' : 'bg-amber-50 text-amber-700';
                    ?>
                    <span class="px-2 py-0.5 rounded-full text-xs font-semibold <?= $typeCls ?>"><?= $typeLabel ?></span>
                  </td>
                  <td class="py-3 pr-4 font-semibold text-slate-900"><?= e($t['passenger_name'] ?? '—') ?></td>
                  <td class="py-3 text-right font-semibold text-slate-900"><?= fcfa((int)$t['price_fcfa']) ?></td>
                  <td class="py-3 pl-4">
                    <span class="px-2 py-0.5 rounded-full text-xs font-semibold <?= $ticketStatusCls[$t['status']] ?? 'bg-slate-100 text-slate-600' ?>">
                      <?= e($t['status']) ?>
                    </span>
                  </td>
                </tr>
                <?php endforeach ?>
              </tbody>
            </table>
          </div>
        <?php endif ?>
      </div>
    </div>
  </div>
</div>
<?php $view->end() ?>
