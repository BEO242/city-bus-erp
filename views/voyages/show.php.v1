<?php
/** @var \CityBus\Core\View $view */
$view->extends('layouts/app');

$booked      = array_flip(array_map('intval', $bookedSeats));
$totalSeats  = (int)($trip['bus_seats'] ?? 0);
$soldCount   = count($bookedSeats);
$occupancy   = $totalSeats > 0 ? round($soldCount / $totalSeats * 100) : 0;
$revenue     = (int)($trip['total_revenue'] ?? array_sum(array_column($tickets, 'price_fcfa')));
$crewByRole  = [];
foreach ($crew as $c) { $crewByRole[$c['role']][] = $c; }

$passengerTickets = array_filter($tickets, fn($t) => in_array($t['ticket_type'], ['passager','arret_route']));
$baggageTickets   = array_filter($tickets, fn($t) => in_array($t['ticket_type'], ['bagage_franchise','bagage_excedent']));

